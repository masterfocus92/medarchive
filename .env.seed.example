# Шаблон данных seed-скрипта (T2.1-BE, ADR-009).
# Скопируй: cp .env.seed.example .env.seed — и заполни реальными данными.
# .env.seed в .gitignore: реальные ФИО, email и пароли в git не попадают.
#
# Даты — ГГГГ-ММ-ДД. Пол: male | female.
# Пароли в шаблоне пусты сознательно: запуск с пустым паролем падает.
# Отчество (MIDDLE_NAME) можно оставить пустым — оно опционально.

SEED_ADULT1_LAST_NAME=Фамилия
SEED_ADULT1_FIRST_NAME=Имя
SEED_ADULT1_MIDDLE_NAME=Отчество
SEED_ADULT1_BIRTH_DATE=1990-01-01
SEED_ADULT1_SEX=male
SEED_ADULT1_EMAIL=parent1@example.com
SEED_ADULT1_PASSWORD=

SEED_ADULT2_LAST_NAME=Фамилия
SEED_ADULT2_FIRST_NAME=Имя
SEED_ADULT2_MIDDLE_NAME=Отчество
SEED_ADULT2_BIRTH_DATE=1990-01-01
SEED_ADULT2_SEX=female
SEED_ADULT2_EMAIL=parent2@example.com
SEED_ADULT2_PASSWORD=

SEED_CHILD_LAST_NAME=Фамилия
SEED_CHILD_FIRST_NAME=Имя
SEED_CHILD_MIDDLE_NAME=Отчество
SEED_CHILD_BIRTH_DATE=2024-01-01
SEED_CHILD_SEX=female
