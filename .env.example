# Скопируй в .env — дефолтов достаточно для локальной разработки.

# Подключение приложения к БД. Хост/порт/креды соответствуют
# сервису db из docker-compose.yml.
DATABASE_URL=postgresql+psycopg://medarchive:medarchive@localhost:5432/medarchive

# Каталог хранения файлов записей (создаётся при первом сохранении).
FILES_DIR=./files

# Секрет подписи session-cookie: минимум 32 символа, у каждой машины свой.
# Сгенерировать: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Креды контейнера Postgres (читает docker compose).
# Должны совпадать с DATABASE_URL выше.
POSTGRES_USER=medarchive
POSTGRES_PASSWORD=medarchive
POSTGRES_DB=medarchive

# AI-экстрактор (ADR-014): провайдер, база, модель. Ключ — только в .env.
EXTRACTOR_PROVIDER=openai_compatible
EXTRACTOR_BASE_URL=https://routerai.ru/api/v1
EXTRACTOR_MODEL=anthropic/claude-sonnet-5
EXTRACTOR_API_KEY=

# Эмбеддинги поиска (ADR-018): тот же RouterAI, модель baai/bge-m3 (1024).
EMBEDDINGS_PROVIDER=openai_compatible
EMBEDDINGS_BASE_URL=https://routerai.ru/api/v1
EMBEDDINGS_MODEL=baai/bge-m3
EMBEDDINGS_API_KEY=

# Параметры retrieval (❓6 потока поиска): K и порог «не нашлось»
# (косинусная дистанция). Дефолты в коде те же — переменные можно не задавать.
SEARCH_TOP_K=5
SEARCH_MAX_DISTANCE=0.75
