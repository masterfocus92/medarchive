# .env стенд-контура — /opt/medarchive/stg/.env (вне git!)
# СВОИ значения: SECRET_KEY не совпадает с продом (сессии не пересекаются),
# ключ RouterAI отдельный (расходы стенда видны отдельно).
DATABASE_URL=postgresql+psycopg://medcard_stg:CHANGE_ME_DB_PASSWORD@localhost:5432/medcard_stg
FILES_DIR=/var/lib/medarchive/stg/files
SECRET_KEY=CHANGE_ME_32_PLUS_CHARS_OTHER_THAN_PROD
APP_ENV=stg

EXTRACTOR_PROVIDER=openai_compatible
EXTRACTOR_BASE_URL=https://routerai.ru/api/v1
EXTRACTOR_MODEL=anthropic/claude-sonnet-5
EXTRACTOR_API_KEY=CHANGE_ME_STG_KEY

# Эмбеддинги поиска (Э7, ADR-018): тот же RouterAI, ключ — ключ контура.
# После первого деплоя этапа 7, после смены модели и после prod2stg
# (пока Э7 не на проде): uv run python -m app.tools.reindex
EMBEDDINGS_PROVIDER=openai_compatible
EMBEDDINGS_BASE_URL=https://routerai.ru/api/v1
EMBEDDINGS_MODEL=baai/bge-m3
EMBEDDINGS_API_KEY=CHANGE_ME_STG_KEY

# Параметры retrieval (❓6): дефолты совпадают с кодом, строки можно опустить.
SEARCH_TOP_K=5
SEARCH_MAX_DISTANCE=0.75
