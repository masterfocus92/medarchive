# /etc/systemd/system/medarchive-stg.service
[Unit]
Description=Семейная медкарта — стенд (stg.mdkarta.online)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=medarchive
Group=medarchive
WorkingDirectory=/opt/medarchive/stg
ExecStart=/usr/local/bin/uv run --no-sync uvicorn app.main:create_app --factory --host 127.0.0.1 --port 8001
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
