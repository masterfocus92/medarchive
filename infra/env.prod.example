# .env прод-контура — /opt/medarchive/prod/.env (вне git!)
# Скопировать, заполнить CHANGE_ME. Генерация секрета: openssl rand -hex 32
DATABASE_URL=postgresql+psycopg://medcard_prod:CHANGE_ME_DB_PASSWORD@localhost:5432/medcard_prod
FILES_DIR=/var/lib/medarchive/prod/files
SECRET_KEY=CHANGE_ME_32_PLUS_CHARS
APP_ENV=prod

# AI-экстрактор (ADR-014). Свой ключ у каждого контура.
EXTRACTOR_PROVIDER=openai_compatible
EXTRACTOR_BASE_URL=https://routerai.ru/api/v1
EXTRACTOR_MODEL=anthropic/claude-sonnet-5
EXTRACTOR_API_KEY=CHANGE_ME
